{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "AllowSnsToSqs",
      "Effect": "Allow",
      "Principal": {
        "Service": "sns.amazonaws.com"
      },
      "Action": "sqs:SendMessage",
      "Resource": "arn:aws:sqs:us-east-1:000000000000:fuzz-queue",
      "Condition": {
        "ArnEquals": {
          "aws:SourceArn": "arn:aws:sns:us-east-1:000000000000:fuzz-topic"
        }
      }
    }
  ]
}
