FLOCI_ENDPOINT=http://localhost:4566
AWS_DEFAULT_REGION=us-east-1

# Permissive Floci (upstream / local dev without enforcement):
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test

# CTF fork (floci-ctf with IAM enforcement enabled):
# Use operator root for provisioning, or participant IAM keys from CreateAccessKey:
# AWS_ACCESS_KEY_ID=AKIA...
# AWS_SECRET_ACCESS_KEY=...
# FLOCI_AUTH_ROOT_ACCESS_KEY_ID=AKIA...
# FLOCI_AUTH_ROOT_SECRET_ACCESS_KEY=...
