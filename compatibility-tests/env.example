FLOCI_ENDPOINT=http://localhost:4566
AWS_DEFAULT_REGION=us-east-1

# ── Permissive profile (upstream Floci / local dev without enforcement) ──────
# Copy to .env and leave FLOCI_CTF_PROFILE unset or set to permissive.
FLOCI_CTF_PROFILE=permissive
FLOCI_IAM_ENFORCEMENT=false
FLOCI_CLOUDTRAIL_AUDIT_ENABLED=false

AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test

# ── CTF profile (floci-ctf Compose: IAM enforcement + SigV4) ─────────────────
# Set FLOCI_CTF_PROFILE=ctf and replace AWS_* with operator root or participant IAM keys.
# FLOCI_CTF_PROFILE=ctf
# FLOCI_IAM_ENFORCEMENT=true
# AWS_ACCESS_KEY_ID=AKIA...
# AWS_SECRET_ACCESS_KEY=...
# FLOCI_AUTH_ROOT_ACCESS_KEY_ID=AKIA...
# FLOCI_AUTH_ROOT_SECRET_ACCESS_KEY=...

# ── Audit exercise (floci-ctf Compose defaults: hybrid storage + CloudTrail audit) ─
# Use with operator root credentials. Enables sdk-test-java ForensicLabCompatibilityTest.
# FLOCI_CTF_PROFILE=ctf
# FLOCI_IAM_ENFORCEMENT=true
# FLOCI_CLOUDTRAIL_AUDIT_ENABLED=true
# FLOCI_AUTH_ROOT_ACCESS_KEY_ID=AKIA...
# FLOCI_AUTH_ROOT_SECRET_ACCESS_KEY=...
# AWS_ACCESS_KEY_ID=AKIA...
# AWS_SECRET_ACCESS_KEY=...
